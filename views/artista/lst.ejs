<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Artistas</h2>
            <a href="/artista/add" class="btn btn-success">+ Novo Artista</a>
            <form method="post"> </br>
                <div class="form-group">
                <input type="text" name="pesquisar" placeholder="Nome da Artista">
                <input class="btn btn-success" type="submit" value="Buscar">
              </div>
            </form>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>País</th>
                        <th>Ano Início</th>
                        <th>Excluir</th>
                        <th>Editar</th>
                    </tr>
                </thead>
                <tbody>
                    <% artistas.forEach(artista => { %>
                        <tr>
                            <td><%= artista.nome %></td>
                            <td><%= artista.pais %></td>
                            <td><%= artista.anoInicio %></td>
                            <td><a href="/artista/del/<%= artista.id %>" class="link">EXCLUIR</a></td>
                            <td><a href="/artista/edt/<%= artista.id %>" class="link">EDITAR</a></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>