<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/artista/lst" class="back-link">← Voltar para Artista</a>

        <div class="form-container">
            <h2>Editar Artista</h2>
            
            <form method="post">
              <div class="form-group">
                    <label for="nome">Nome do Artista *</label>
                    <input 
                        type="text" 
                        id="id" 
                        name="id" 
                        value="<%=artista.id%>"
                        required
                    >
                </div>
                <div class="form-group">
                    <label for="nome">Nome do Artista *</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        value="<%=artista.nome%>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="pais">País *</label>
                    <input 
                        type="text" 
                        id="pais" 
                        name="pais" 
                        value="<%=artista.pais%>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="anoInicio">Ano de Início da Carreira *</label>
                    <input 
                        type="number" 
                        id="anoInicio" 
                        name="anoInicio" 
                        value="<%=artista.anoInicio%>"
                        required
                    >
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Editar</button>
                    <a href="/artista/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>