<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/musica/lst" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Nova Musica</h2>
            
            <form method="post">
                <div class="form-group">
                    <label for="titulo">Título da música*</label>
                    <input 
                        type="text" 
                        id="titulo" 
                        name="titulo" 
                        placeholder="Ex: Alegria, Alegria"
                    >
                </div>
                
                <div class="form-group">
                    <label for="duracao">Duração (minutos) *</label>
                    <input 
                        type="text" 
                        id="duracao" 
                        name="duracao"  
                    >
                </div>

                <div class="form-group">
                    <label for="artista">Artista *</label>
                    <input 
                        type="text" 
                        id="artista" 
                        name="artista" 
                    >
                </div>


                <div class="form-group">
                    <label for="ano">Ano *</label>
                    <input 
                        type="number" 
                        id="ano" 
                        name="ano"  
                    >
                </div>

                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/musica/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>